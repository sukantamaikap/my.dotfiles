{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-conductor-plugin",
    "@openspoon/subtask2",
    "opencode-dynamic-context-pruning"
  ],
  "mcp": {
    "searxng-researcher": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-shell-command",
        "--name",
        "web_search",
        "--command",
        "/Users/sukantamaikap/.config/searxng/scripts/search-tool.sh",
        "--description",
        "Searches the internet for real-time tech docs, news, and DevOps trends."
      ],
      "enabled": true
    },
    "paddle-billing": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@paddle/mcp-server"
      ],
      "enabled": false,
      "environment": {
        "PADDLE_API_KEY": "${PADDLE_API_KEY}",
        "PADDLE_ENVIRONMENT": "sandbox"
      }
    },
    "paddle-docs": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@paddle/mcp-docs-server"
      ],
      "enabled": false
    },
    "daisyui-github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://gitmcp.io/saadeghi/daisyui"
      ],
      "enabled": false
    },
    "solidjs-skills": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "solidjskills@latest"
      ],
      "enabled": false
    },
    "go-analyzer": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-golang@latest"
      ],
      "enabled": false
    },
    "terraform": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "terraform-mcp-server@latest"
      ],
      "enabled": false,
      "note": "Provides Terraform Registry API access and HCL pattern analysis."
    },
    "lgtm-grafana": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@grafana/mcp-grafana"
      ],
      "enabled": false,
      "environment": {
        "GRAFANA_URL": "http://localhost:3000",
        "GRAFANA_TOKEN": "${GRAFANA_TOKEN}"
      }
    },
    "otel-docs": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@opentelemetry/mcp-docs-server"
      ],
      "enabled": false
    },
    "redis-manager": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-redis@latest"
      ],
      "enabled": false,
      "environment": {
        "REDIS_URL": "redis://localhost:6379"
      }
    }
  },
}
