{
  "lastChangelogVersion": "0.73.0",
  "defaultProvider": "opencode",
  "defaultModel": "kimi-k2.6",
  "defaultThinkingLevel": "medium",
  "plugin_paths": [
    "./plugins/local"
  ],
  "enabled_plugins": [
    "shell_guard",
    "fs_sentinel",
    "workflow_enforcer"
  ],
  "capabilities": {
    "shell": {
      "allow_list": [
        "go *",
        "docker ps",
        "docker images",
        "git status",
        "git diff",
        "git log"
      ],
      "require_approval": [
        "git commit",
        "git push",
        "docker build",
        "docker run"
      ],
      "deny_list": [
        "rm -rf /",
        "chmod",
        "chown"
      ]
    }
  }
}
